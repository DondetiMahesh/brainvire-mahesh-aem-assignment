<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Media Card"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <mainTab
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <contentTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Card Content"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <sectionTitle
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldDescription="Heading shown above the group of cards."
                                fieldLabel="Heading"
                                name="./sectionTitle"/>
                            <cardItems
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                composite="{Boolean}true"
                                fieldDescription="Add multiple content cards with media and text."
                                fieldLabel="Content Cards">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    fieldLabel="Media Field"
                                    name="./mediaField">
                                    <items jcr:primaryType="nt:unstructured">
                                        <accordion1
                                            granite:class="js-cq-IPEPlugin-container"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/accordion"
                                            variant="quiet">
                                            <items jcr:primaryType="nt:unstructured">
                                                <mediatypesselector
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Media Type Selector"
                                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                                    maximized="{Boolean}true">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <typeSelector
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/foundation/form/select"
                                                            fieldDescription="Select whether the card includes an image or a video."
                                                            fieldLabel="Media Type"
                                                            name="./selectMedia">
                                                            <items jcr:primaryType="nt:unstructured">
                                                                <image
                                                                    jcr:primaryType="nt:unstructured"
                                                                    text="Image"
                                                                    value="image"/>
                                                                <video
                                                                    jcr:primaryType="nt:unstructured"
                                                                    text="Video"
                                                                    value="video"/>
                                                            </items>
                                                        </typeSelector>
                                                        <assetPath
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                            fieldDescription="Path to the image or video asset in the DAM."
                                                            fieldLabel="Media Asset Path"
                                                            name="./mediaSrc"
                                                            rootPath="/content/dam"/>
                                                        <altOrFormat
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldDescription="Enter alt text for images or video format (e.g., MP4, YouTube)."
                                                            fieldLabel="Alt Text or Format"
                                                            name="./mediaMetadata"/>
                                                        <cardHeading
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldDescription="The main heading displayed on the card."
                                                            fieldLabel="Card Heading"
                                                            name="./title"/>
                                                        <cardSummary
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                                            fieldDescription="Short description or summary of the card content."
                                                            fieldLabel="Card Summary"
                                                            name="./description"/>
                                                        <ctaText
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldDescription="Text shown on the call-to-action button."
                                                            fieldLabel="CTA Label"
                                                            name="./buttonText"/>
                                                        <ctaLink
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                            fieldDescription="Destination URL or path for the CTA button."
                                                            fieldLabel="CTA Link"
                                                            name="./buttonLink"/>
                                                        <ctaNewTab
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                            fieldDescription="Check to open the CTA link in a new browser tab."
                                                            fieldLabel="Open CTA in New Tab"
                                                            name="./openNewTab"
                                                            text="Open in New Tab"
                                                            uncheckedValue="false"
                                                            value="{Boolean}true"/>
                                                    </items>
                                                </mediatypesselector>
                                            </items>
                                        </accordion1>
                                    </items>
                                </field>
                            </cardItems>
                        </items>
                    </contentTab>
                </items>
            </mainTab>
        </items>
    </content>
</jcr:root>
